<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="in.co.rays.project_3.dto">

	<class name="InsuranceDTO" table="ST_INSURANCE">

		<!-- Primary Key -->
		<id name="id" type="java.lang.Long">
			<column name="ID" />
			<generator class="increment" />
		</id>

		<!-- Insurance Fields -->
		<property name="insuranceCode" type="java.lang.String">
			<column name="INSURANCECODE" />
		</property>

		<property name="premiumAmount" type="long">
			<column name="PREMIUMAMOUNT" />
		</property>

		<property name="policyHolder" type="java.lang.String">
			<column name="POLICYHOLDER" />
		</property>

		<property name="status" type="java.lang.String">
			<column name="STATUS" />
		</property>

		<!-- BaseDTO fields -->
		<property name="createdBy" type="java.lang.String">
			<column name="CREATED_BY" />
		</property>

		<property name="modifiedBy" type="java.lang.String">
			<column name="MODIFIED_BY" />
		</property>

		<property name="createdDatetime" type="java.sql.Timestamp">
			<column name="CREATED_DATETIME" />
		</property>

		<property name="modifiedDatetime" type="java.sql.Timestamp">
			<column name="MODIFIED_DATETIME" />
		</property>

	</class>

</hibernate-mapping>