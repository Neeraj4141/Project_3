<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="in.co.rays.project_3.dto">

	<class name="RuleDTO" table="ST_RULE">

		<id name="id" type="java.lang.Long">
			<column name="ID"></column>
			<generator class="increment"></generator>
		</id>

		<property name="ruleCode" type="java.lang.String">
			<column name="RULECODE" />
		</property>

		<property name="triggerType" type="java.lang.String">
			<column name="TRIGGERTYPE" />
		</property>

		<property name="event" type="java.lang.String">
			<column name="EVENT" />
		</property>

		<property name="status" type="java.lang.String">
			<column name="STATUS" />
		</property>

		<!-- BaseDTO ke common fields -->
		<property name="createdBy" type="java.lang.String" length="50">
			<column name="CREATED_BY" />
		</property>

		<property name="modifiedBy" type="java.lang.String" length="50">
			<column name="MODIFIED_BY" />
		</property>

		<property name="createdDatetime" type="java.sql.Timestamp">
			<column name="CREATED_DATETIME" />
		</property>

		<property name="modifiedDatetime" type="java.sql.Timestamp">
			<column name="MODIFIED_DATETIME" />
		</property>

	</class>

</hibernate-mapping>