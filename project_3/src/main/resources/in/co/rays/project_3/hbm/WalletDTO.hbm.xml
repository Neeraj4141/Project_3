<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="in.co.rays.project_3.dto">

    <class name="WalletDTO" table="ST_WALLET">

        <!-- Primary Key (walletId as ID) -->
        <id name="walletId" type="java.lang.Long">
            <column name="WALLET_ID"/>
            <generator class="increment"/>
        </id>

        <!-- Other Fields -->
        <property name="balance" type="java.lang.String">
            <column name="BALANCE"/>
        </property>

        <property name="walletCode" type="java.lang.String">
            <column name="WALLET_CODE"/>
        </property>

        <property name="userName" type="java.lang.String">
            <column name="USER_NAME"/>
        </property>

        <property name="status" type="java.lang.String">
            <column name="STATUS"/>
        </property>

        <!-- Common Fields -->
        <property name="createdBy" type="java.lang.String">
            <column name="CREATED_BY"/>
        </property>

        <property name="modifiedBy" type="java.lang.String">
            <column name="MODIFIED_BY"/>
        </property>

        <property name="createdDatetime" type="java.sql.Timestamp">
            <column name="CREATED_DATETIME"/>
        </property>

        <property name="modifiedDatetime" type="java.sql.Timestamp">
            <column name="MODIFIED_DATETIME"/>
        </property>

    </class>

</hibernate-mapping>