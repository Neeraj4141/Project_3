<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="in.co.rays.project_3.dto">

	<class name="EmployeeDTO" table="ST_EMPLOYEE">

		<id name="id" type="java.lang.Long">
			<column name="ID"></column>
			<generator class="increment"></generator>
		</id>

		<property name="employeeName" type="java.lang.String">
			<column name="EMPLOYEE_NAME" />
		</property>

		<property name="address" type="java.lang.String">
			<column name="ADDRESS" />
		</property>

		<property name="role" type="java.lang.Long">
			<column name="ROLE" />
		</property>

		<property name="gender" type="java.lang.String">
			<column name="GENDER" />
		</property>

		<property name="joiningDate" type="java.util.Date">
			<column name="JOINING_DATE" />
		</property>

		<property name="email" type="java.lang.String">
			<column name="EMAIL" />
		</property>

		<property name="employeeCode" type="java.lang.String">
			<column name="EMPLOYEE_CODE" />
		</property>

		<!-- BaseDTO fields (same as UserDTO sample) -->

		<property name="createdBy" type="java.lang.String" length="50">
			<column name="CREATED_BY" />
		</property>

		<property name="modifiedBy" type="java.lang.String" length="50">
			<column name="MODIFIED_BY" />
		</property>

		<property name="createdDatetime" type="java.sql.Timestamp">
			<column name="CREATED_DATETIME" />
		</property>

		<property name="modifiedDatetime" type="java.sql.Timestamp">
			<column name="MODIFIED_DATETIME" />
		</property>

	</class>

</hibernate-mapping>