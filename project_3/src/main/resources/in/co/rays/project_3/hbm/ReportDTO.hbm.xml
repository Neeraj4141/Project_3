<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="in.co.rays.project_3.dto">

    <class name="ReportDTO" table="ST_REPORT">

        <!-- Primary Key -->
        <id name="id" type="java.lang.Long">
            <column name="ID" />
            <generator class="increment" />
        </id>

        <!-- Report Fields -->
        <property name="repairNo" type="java.lang.Long">
            <column name="REPAIRNO" />
        </property>

        <property name="cost" type="java.lang.String">
            <column name="COST" />
        </property>

        <property name="repairDate" type="java.util.Date">
            <column name="REPAIRDATE" />
        </property>

        <property name="deviceName" type="java.lang.String">
            <column name="DEVICENAME" />
        </property>

        <!-- BaseDTO fields -->
        <property name="createdBy" type="java.lang.String">
            <column name="CREATED_BY" />
        </property>

        <property name="modifiedBy" type="java.lang.String">
            <column name="MODIFIED_BY" />
        </property>

        <property name="createdDatetime" type="java.sql.Timestamp">
            <column name="CREATED_DATETIME" />
        </property>

        <property name="modifiedDatetime" type="java.sql.Timestamp">
            <column name="MODIFIED_DATETIME" />
        </property>

    </class>

</hibernate-mapping>