<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
	<subclass name="in.co.rays.project_3.dto.ContractDTO"
		extends="in.co.rays.project_3.dto.BaseDTO"
		discriminator-value="ContractDTO" lazy="false">
		<property name="contractCode" type="java.lang.String">
			<column name="CONTRACTCODE" />
		</property>
		<property name="endDate" type="java.util.Date">
			<column name="ENDDATE" />
		</property>
		<property name="contractName" type="java.lang.String">
			<column name="CONTRACTNAME" />
		</property>
		<property name="startDate" type="java.util.Date">
			<column name="STARTDATE" />
		</property>
	</subclass>
</hibernate-mapping>
